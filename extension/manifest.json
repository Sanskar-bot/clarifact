{
  "manifest_version": 3,
  "name": "ClariFact",
  "version": "1.1.0",
  "description": "Fact-check any selected text instantly. ClariFact searches the web and uses Nemotron AI to give you a structured verdict with confidence score and evidence.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "https://clarifact.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/compromise.min.js",
        "scraper.js",
        "nlp.js",
        "scorer.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ClariFact — AI Fact Checker",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "lib/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
