# ─────────────────────────────────────────────────────────────
# Clarifact Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────
# Which AI to use for fact-check analysis.
#   auto    = Try Gemini first, fall back to Bedrock (recommended)
#   gemini  = Always use Google Gemini
#   bedrock = Always use Amazon Bedrock / Claude
AI_PROVIDER=auto

# ── Google Gemini ──────────────────────────────────────────────
# Free tier: 15 req/min, 1M tokens/day — no credit card needed
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Brave Search API ───────────────────────────────────────────
# Get your free key at: https://brave.com/search/api/
BRAVE_API_KEY=YOUR_BRAVE_SEARCH_API_KEY_HERE

# ── Amazon Bedrock Auth — OPTION A (Easiest) ──────────────────
# Use the long-term API key from:
#   Amazon Bedrock Console → API keys → Generate long-term API key
# The key starts with ABSKQm...
AWS_BEARER_TOKEN_BEDROCK=YOUR_BEDROCK_API_KEY_HERE

# ── Amazon Bedrock Auth — OPTION B (IAM credentials) ──────────
# Only needed if you are NOT using the bearer token above.
# Leave blank if using OPTION A.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── AWS Region ─────────────────────────────────────────────────
AWS_REGION=ap-south-1

# ── Server ─────────────────────────────────────────────────────
PORT=3000
ALLOWED_EXTENSION_ID=
