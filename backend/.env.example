# ─────────────────────────────────────────────────────────────────────────────
# Clarifact Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Provider ───────────────────────────────────────────────────────────────
# Which AI to use for fact-check analysis.
#   nemotron = Nvidia Nemotron Nano 3 30B via AWS Bedrock IAM (recommended)
#   auto     = Try Nemotron → Gemini → Bedrock/Claude in order
#   gemini   = Always use Google Gemini 1.5 Flash (free tier)
#   bedrock  = Always use Amazon Bedrock / Claude (bearer token)
AI_PROVIDER=nemotron

# ── Nvidia Nemotron Nano 3 30B (primary AI provider) ─────────────────────────
# Uses AWS IAM credentials below — no extra key needed.
# Optional: only set this if you want to test a different Nemotron variant.
# Defaults to "nvidia.nemotron-nano-3-30b" if left blank.
NEMOTRON_MODEL_ID=

# ── Google Gemini (optional secondary AI) ─────────────────────────────────────
# Free tier: 15 req/min, 1M tokens/day — no credit card needed.
# Get key: https://aistudio.google.com/apikey
# Used as fallback when AI_PROVIDER=auto and Nemotron fails.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Web Search ────────────────────────────────────────────────────────────────
#
# OPTION A — Tavily API (recommended for real news claims)
#   Free tier: 1,000 searches/month, no credit card required.
#   Sign up:   https://app.tavily.com/sign-up
#   If left blank, the app automatically falls back to the free Wikipedia API,
#   which works well for established facts but will NOT find recent news claims.
TAVILY_API_KEY=

# ── Amazon Bedrock Auth — OPTION A (bearer token, easiest) ───────────────────
# Generate from: Amazon Bedrock Console → API keys → Generate long-term API key
# The key starts with ABSKQm... and is used only for Claude/Bedrock fallback.
AWS_BEARER_TOKEN_BEDROCK=YOUR_BEDROCK_API_KEY_HERE

# ── Amazon Bedrock Auth — OPTION B (IAM credentials, required for Nemotron) ──
# Create an IAM user with AmazonBedrockFullAccess, then generate an access key.
# How-to: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html
# Run "npm run check-aws" after filling these in to verify the connection.
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE

# ── AWS Region ────────────────────────────────────────────────────────────────
# Must match the region where you have Bedrock Model Access enabled.
AWS_REGION=ap-south-1

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# Optional: lock the extension to a specific Chrome Extension ID for security.
# Leave blank during development (all local connections accepted).
ALLOWED_EXTENSION_ID=
